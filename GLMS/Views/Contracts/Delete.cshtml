@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h1><i class="fas fa-trash-alt"></i> Delete Contract</h1>
<hr />

<div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this contract?
    <strong>This will also delete all associated service requests!</strong>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Contract Number</dt>
            <dd class="col-sm-9">@Model.ContractNumber</dd>

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Value</dt>
            <dd class="col-sm-9">$@Model.ContractValueUSD.ToString("N2")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="ContractId" />
    <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>