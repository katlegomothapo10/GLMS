@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h1><i class="fas fa-info-circle"></i> Contract Details</h1>
<hr />

<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">@Model.ContractNumber</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Contract Number</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ContractNumber)</dd>

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Client.Name)</dd>

            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="status-badge status-@Model.StatusBadgeClass">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceLevel)</dd>

            <dt class="col-sm-3">Contract Value (USD)</dt>
            <dd class="col-sm-9">$@Model.ContractValueUSD.ToString("N2")</dd>

            <dt class="col-sm-3">Special Terms</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.SpecialTerms)</dd>

            <dt class="col-sm-3">Signed Agreement</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <a href="@Url.Action("DownloadFile", new { id = Model.ContractId })" class="btn btn-sm btn-success">
                        <i class="fas fa-download"></i> Download PDF
                    </a>
                }
                else
                {
                    <span class="text-muted">No agreement uploaded</span>
                }
            </dd>

            <dt class="col-sm-3">Created Date</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
    </div>
</div>

@if (Model.ServiceRequests.Any())
{
    <h3>Service Requests</h3>
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Request #</th>
                            <th>Description</th>
                            <th>Cost (USD)</th>
                            <th>Cost (ZAR)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model.ServiceRequests)
                        {
                            <tr>
                                <td>@request.RequestNumber</td>
                                <td>@request.Description</td>
                                <td>$@request.CostUSD.ToString("N2")</td>
                                <td>R@request.CostZAR.ToString("N2")</td>
                                <td>@request.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>