@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<h1><i class="fas fa-edit"></i> Edit Contract</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ContractId" />
            <input type="hidden" asp-for="ContractNumber" />
            <input type="hidden" asp-for="SignedAgreementPath" />

            <div class="form-group mb-3">
                <label asp-for="ClientId" class="form-label"></label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.Clients">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<GLMS.Models.ContractStatus>()"></select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="ServiceLevel" class="form-label"></label>
                        <select asp-for="ServiceLevel" class="form-control" asp-items="Html.GetEnumSelectList<GLMS.Models.ServiceLevel>()"></select>
                        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ContractValueUSD" class="form-label"></label>
                <input asp-for="ContractValueUSD" class="form-control" />
                <span asp-validation-for="ContractValueUSD" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SpecialTerms" class="form-label"></label>
                <textarea asp-for="SpecialTerms" class="form-control" rows="3"></textarea>
                <span asp-validation-for="SpecialTerms" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <div class="form-group mb-3">
                    <label class="form-label">Current Agreement</label>
                    <div>
                        <a href="@Url.Action("DownloadFile", new { id = Model.ContractId })" class="btn btn-sm btn-info">
                            <i class="fas fa-download"></i> Download Current PDF
                        </a>
                    </div>
                </div>
            }

            <div class="form-group mb-3">
                <label class="form-label">Replace Agreement (Optional)</label>
                <input type="file" name="SignedAgreement" class="form-control" accept=".pdf" />
                <small class="text-muted">Upload new PDF to replace existing agreement.</small>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}