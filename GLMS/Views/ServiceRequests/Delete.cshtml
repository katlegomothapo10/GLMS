@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h1><i class="fas fa-trash-alt"></i> Delete Service Request</h1>
<hr />

<div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this service request?
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Request Number</dt>
            <dd class="col-sm-9">@Model.RequestNumber</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Cost</dt>
            <dd class="col-sm-9">$@Model.CostUSD.ToString("N2") (R@Model.CostZAR.ToString("N2"))</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="ServiceRequestId" />
    <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>