@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<h1><i class="fas fa-edit"></i> Edit Service Request</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ServiceRequestId" />
            <input type="hidden" asp-for="RequestNumber" />
            <input type="hidden" asp-for="ExchangeRateUsed" />
            <input type="hidden" asp-for="CostZAR" />

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="form-label"></label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.Contracts">
                    <option value="">-- Select Active Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CostUSD" class="form-label">Cost (USD)</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="CostUSD" class="form-control" id="costUSD" />
                </div>
                <span asp-validation-for="CostUSD" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Cost (ZAR) - Calculated</label>
                <div class="input-group">
                    <span class="input-group-text">R</span>
                    <input type="text" id="costZAR" class="form-control" readonly disabled />
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<GLMS.Models.RequestStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SpecialInstructions" class="form-label"></label>
                <textarea asp-for="SpecialInstructions" class="form-control" rows="3"></textarea>
                <span asp-validation-for="SpecialInstructions" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        const exchangeRate = @Model.ExchangeRateUsed;
        
        function updateZAR() {
            const usd = parseFloat(document.getElementById('costUSD').value) || 0;
            const zar = usd * exchangeRate;
            document.getElementById('costZAR').value = zar.toFixed(2);
        }
        
        document.getElementById('costUSD').addEventListener('input', updateZAR);
        updateZAR();
    </script>
}