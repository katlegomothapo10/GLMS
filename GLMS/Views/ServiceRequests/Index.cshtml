@model IEnumerable<GLMS.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-truck"></i> Service Requests</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> New Service Request
    </a>
</div>

<!-- Search and Filter Section -->
<div class="card mb-4">
    <div class="card-header bg-secondary text-white">
        <i class="fas fa-filter"></i> Search & Filter
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <input type="text" name="searchString" class="form-control" placeholder="Request #, Contract #, Description..." value="@ViewBag.CurrentSearchString" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-control" asp-items="ViewBag.StatusFilter">
                        <option value="">All</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Min Cost (USD)</label>
                    <input type="number" name="minCost" class="form-control" placeholder="Min $" value="@ViewBag.CurrentMinCost" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Cost (USD)</label>
                    <input type="number" name="maxCost" class="form-control" placeholder="Max $" value="@ViewBag.CurrentMaxCost" step="0.01" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary form-control"><i class="fas fa-search"></i> Search</button>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.CurrentStartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.CurrentEndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">&nbsp;</label>
                    <a asp-action="Index" class="btn btn-secondary">Clear Filters</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No service requests found. Click "New Service Request" to create one.
    </div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Request #</th>
                            <th>Contract</th>
                            <th>Client</th>
                            <th>Description</th>
                            <th>Cost (USD)</th>
                            <th>Cost (ZAR)</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequestNumber</td>
                                <td>@item.Contract?.ContractNumber</td>
                                <td>@item.Contract?.Client?.Name</td>
                                <td>@item.Description</td>
                                <td>$@item.CostUSD.ToString("N2")</td>
                                <td>R@item.CostZAR.ToString("N2")</td>
                                <td>
                                    @if (item.Status == GLMS.Models.RequestStatus.Completed)
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == GLMS.Models.RequestStatus.Cancelled)
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else if (item.Status == GLMS.Models.RequestStatus.InProgress)
                                    {
                                        <span class="badge bg-primary">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">@item.Status</span>
                                    }
                                </td>
                                <td>@item.RequestedDate.ToShortDateString()</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-info" title="Details">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    @if (item.Status == GLMS.Models.RequestStatus.Pending)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    }
                                    <form asp-action="UpdateStatus" asp-route-id="@item.ServiceRequestId" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newStatus" value="@((int)GLMS.Models.RequestStatus.InProgress)" />
                                        <button type="submit" class="btn btn-sm btn-primary" title="Start">
                                            <i class="fas fa-play"></i>
                                        </button>
                                    </form>
                                    <form asp-action="UpdateStatus" asp-route-id="@item.ServiceRequestId" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newStatus" value="@((int)GLMS.Models.RequestStatus.Completed)" />
                                        <button type="submit" class="btn btn-sm btn-success" title="Complete">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                    <form asp-action="UpdateStatus" asp-route-id="@item.ServiceRequestId" method="post" style="display: inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="newStatus" value="@((int)GLMS.Models.RequestStatus.Cancelled)" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Cancel">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}